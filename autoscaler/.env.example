# Railrunner autoscaler — set these as Railway service variables.
# (Railway's "Suggested Variables" can't auto-detect all of them, so use this list.)

# --- Required ---
GITHUB_TOKEN=          # GitHub PAT with "Actions: Read" on every repo you watch
RAILWAY_TOKEN=         # a Railway PROJECT token (Project -> Settings -> Tokens)
RUNNER_SERVICE_ID=     # the RUNNER service's ID (NOT this autoscaler's service)

# --- What to watch: set REPOS and/or GITHUB_ORG (at least one) ---
REPOS=                 # comma-separated owner/repo, e.g. acme/api,acme/web
GITHUB_ORG=            # watch every active repo in this org (small orgs — see rate-limit note)

# --- Recommended ---
RUNNER_REGION=us-west  # your runner's region: us-west | us-east | eu-west | southeast-asia
DRY_RUN=true           # log decisions without scaling; set false once it looks right

# --- Optional (defaults shown) ---
MIN_RUNNERS=1          # floor; set 0 to scale to zero when idle
MAX_RUNNERS=5          # ceiling (safety cap)
POLL_SECONDS=20        # how often to check GitHub; raise it if you watch many repos
REPO_REFRESH_SECONDS=300  # how often to re-list GITHUB_ORG repos

# Notes:
# - Each watched repo costs ~2 API calls per poll. Keep  repos x (7200 / POLL_SECONDS)
#   under 5000/hour, or raise POLL_SECONDS. Large orgs: use workflow_job webhooks.
# - For org-wide runners, register the runner itself at org scope (RUNNER_SCOPE=org).
# - Do NOT set RAILWAY_API_TOKEN alongside RAILWAY_TOKEN — the CLI allows only one token.
# - RAILWAY_CLI_VERSION is a build-time ARG baked into the image; it is not a runtime variable.
